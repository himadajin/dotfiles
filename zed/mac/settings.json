// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  // = Zed =
  // == Workbench ==
  "base_keymap": "VSCode",
  "cli_default_open_behavior": "existing_window",
  "icon_theme": "Material Icon Theme",
  // == Panels ==
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "project_panel": {
    "dock": "left"
  },
  // == Editor ==
  "autosave": "off",
  "buffer_font_family": "Menlo",
  "buffer_font_fallbacks": ["CodeNewRoman Nerd Font Mono"],
  "buffer_font_size": 12.0,
  "buffer_font_weight": 400.0,
  "buffer_line_height": "comfortable",
  "format_on_save": "off",
  "preferred_line_length": 80,
  "show_whitespaces": "all",
  "soft_wrap": "none",
  "tab_size": 2,
  "ui_font_size": 16,
  // == Files ==
  "file_types": {
    "C++": ["gen", "inc"],
    "JSONC": [
      "json",
      "jsonc",
      "**/.zed/**/*.json",
      "**/zed/**/*.json",
      "**/Zed/**/*.json",
      "**/.vscode/**/*.json"
    ]
  },
  // == AI ==
  "agent": {
    "button": false,
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  // == Languages ==
  "languages": {
    "C": {
      "tab_size": 2,
      "preferred_line_length": 80
    },
    "C++": {
      "tab_size": 2,
      "preferred_line_length": 80
    },
    "JSON": {
      "tab_size": 2
    },
    "JSONC": {
      "tab_size": 2
    },
    "Python": {
      "tab_size": 4
    },
    "Rust": {
      "tab_size": 4,
      "preferred_line_length": 120
    }
  },
  // == Theme ==
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark Pro"
  }
}
