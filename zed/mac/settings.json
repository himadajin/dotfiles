// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  // = Zed =
  // == Workbench ==
  "proxy": "",
  "base_keymap": "VSCode",
  "cli_default_open_behavior": "existing_window",
  "icon_theme": "Material Icon Theme",
  // == UI ==
  "ui_font_family": ".SystemUIFont",
  "ui_font_size": 16.0,
  "ui_font_weight": 400.0,
  // == Panels ==
  "collaboration_panel": {
    "dock": "left"
  },
  "debugger": {
    "dock": "right"
  },
  "git_panel": {
    "dock": "left",
    "sort_by_path": true
  },
  "outline_panel": {
    "dock": "right"
  },
  "project_panel": {
    "auto_fold_dirs": false,
    "dock": "left"
  },
  // == Editor ==
  "autosave": "off",
  "buffer_font_family": "Menlo",
  "buffer_font_fallbacks": ["CodeNewRoman Nerd Font Mono"],
  "buffer_font_size": 12.0,
  "buffer_font_weight": 400.0,
  "buffer_line_height": "comfortable",
  "format_on_save": "off",
  "preferred_line_length": 80,
  "show_whitespaces": "all",
  "show_wrap_guides": true,
  "soft_wrap": "none",
  "tab_size": 2,
  "wrap_guides": [80, 100],
  // == Files ==
  "file_types": {
    "C++": ["gen", "inc"],
    "JSONC": [
      "json",
      "jsonc",
      "**/.zed/**/*.json",
      "**/zed/**/*.json",
      "**/Zed/**/*.json",
      "**/.vscode/**/*.json"
    ]
  },
  // == AI ==
  "agent": {
    "button": false,
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
    "sidebar_side": "right"
  },
  "edit_predictions": {
    "provider": "copilot"
  },
  // == Languages ==
  "languages": {
    "C": {
      "tab_size": 2,
      "preferred_line_length": 80
    },
    "C++": {
      "tab_size": 2,
      "preferred_line_length": 80
    },
    "JSON": {
      "tab_size": 2
    },
    "JSONC": {
      "tab_size": 2
    },
    "Python": {
      "tab_size": 4
    },
    "Rust": {
      "tab_size": 4,
      "preferred_line_length": 120,
      "wrap_guides": [120]
    }
  },
  // == LSP ==
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "check": {
          "command": "clippy"
        }
      }
    }
  },
  // == Theme ==
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "One Dark Pro"
  },
  "theme_overrides": {
    "One Dark Pro": {
      "background": "#101010",
      "border": "#9696af",
      "border.variant": "#9696af",
      "editor.active_line.background": "#282d37",
      "editor.background": "#101010",
      "editor.gutter.background": "#101010",
      "editor.highlighted_line.background": "#282d37",
      "pane.focused_border": "#9696af",
      "pane_group.border": "#9696af",
      "panel.background": "#101010",
      "panel.focused_border": "#9696af",
      "surface.background": "#101010",
      "syntax": {
        "comment": {
          "color": "#afafaf"
        },
        "comment.doc": {
          "color": "#afafaf"
        }
      },
      "tab.active_background": "#101010",
      "tab.inactive_background": "#101010",
      "tab_bar.background": "#101010",
      "terminal.background": "#101010",
      "title_bar.background": "#101010",
      "toolbar.background": "#101010"
    }
  }
}
