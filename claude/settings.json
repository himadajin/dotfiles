{
  "agentPushNotifEnabled": true,
  "effortLevel": "high",
  "enabledPlugins": {
    "codex@openai-codex": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "repo": "openai/codex-plugin-cc",
        "source": "github"
      }
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash '/Users/taiki/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  },
  "inputNeededNotifEnabled": true,
  "model": "sonnet",
  "permissions": {
    "allow": [
      "Bash(awk:*)",
      "Bash(basename:*)",
      "Bash(cat:*)",
      "Bash(clang:*)",
      "Bash(clang++:*)",
      "Bash(cmake:*)",
      "Bash(cut:*)",
      "Bash(df:*)",
      "Bash(diff:*)",
      "Bash(dirname:*)",
      "Bash(du:*)",
      "Bash(echo:*)",
      "Bash(file:*)",
      "Bash(find:*)",
      "Bash(gcc:*)",
      "Bash(g++:*)",
      "Bash(git branch:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git remote:*)",
      "Bash(git show:*)",
      "Bash(git stash list:*)",
      "Bash(git status:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(llc:*)",
      "Bash(llvm-as:*)",
      "Bash(llvm-dis:*)",
      "Bash(llvm-lit:*)",
      "Bash(llvm-nm:*)",
      "Bash(llvm-objdump:*)",
      "Bash(llvm-readelf:*)",
      "Bash(llvm-size:*)",
      "Bash(llvm-strings:*)",
      "Bash(lit:*)",
      "Bash(ls:*)",
      "Bash(make:*)",
      "Bash(mkdir:*)",
      "Bash(nm:*)",
      "Bash(not:*)",
      "Bash(opt:*)",
      "Bash(printf:*)",
      "Bash(pwd:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(readlink:*)",
      "Bash(realpath:*)",
      "Bash(rg:*)",
      "Bash(sort:*)",
      "Bash(stat:*)",
      "Bash(tail:*)",
      "Bash(task:*)",
      "Bash(tee:*)",
      "Bash(touch:*)",
      "Bash(tr:*)",
      "Bash(uname:*)",
      "Bash(uniq:*)",
      "Bash(uv:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(xargs:*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:llvm.org)",
      "WebFetch(domain:npmjs.com)",
      "WebFetch(domain:open-std.org)",
      "WebFetch(domain:pypi.org)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebSearch"
    ],
    "ask": [
      "Bash(chmod:*)",
      "Bash(env:*)",
      "Bash(git push:*)",
      "Bash(git rebase:*)",
      "Bash(git reset:*)",
      "Bash(patch:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Read(**/.bash_history)",
      "Read(**/.zsh_history)"
    ],
    "deny": [
      "Bash(ssh:*)",
      "Bash(sudo:*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/.ssh/**)",
      "Read(**/secrets/**)"
    ]
  },
  "tui": "fullscreen"
}
