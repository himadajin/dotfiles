{
  // = VSCode =
  // == Color Theme ==
  "editor.tokenColorCustomizations": {
    "[One Dark Pro Night Flat]": {
      "comments": "#afafaf"
    }
  },
  "workbench.colorCustomizations": {
    "[One Dark Pro Night Flat]": {
      "editor.foreground": "#f0f0f0",
      // Background Colors
      "editor.background": "#101010",
      "terminal.background": "#101010",
      "sideBar.background": "#101010",
      "activityBar.background": "#101010",
      // Border Colors
      "activityBar.border": "#9696af",
      "editorGroup.border": "#9696af",
      "input.border": "#9696af",
      "panel.border": "#9696af",
      "statusBar.border": "#9696af",
      "sideBar.border": "#9696af",
      "sideBarSectionHeader.border": "#9696af",
      "tab.border": "#9696af",
      "titleBar.border": "#9696af"
    }
  },
  "workbench.colorTheme": "One Dark Pro Night Flat",
  // == Editor ==
  "editor.fontSize": 11.5,
  "editor.fontFamily": "Menlo, Monaco, 'Courier New', monospace, 'CodeNewRoman Nerd Font'",
  "editor.formatOnSave": false,
  "editor.formatOnType": false,
  "editor.maxTokenizationLineLength": 15000,
  "editor.minimap.enabled": false,
  "editor.renderWhitespace": "all",
  "editor.rulers": [80, 100],
  "editor.stickyScroll.enabled": true,
  "editor.tabSize": 2,
  // == Explorer ==
  "explorer.compactFolders": false,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmPasteNative": false,
  // == Terminal ==
  "terminal.integrated.enablePersistentSessions": false,
  "terminal.integrated.initialHint": false,
  "terminal.integrated.stickyScroll.enabled": false,
  "terminal.integrated.suggest.enabled": false,
  // == Workbench ==
  "workbench.secondarySideBar.showLabels": false,
  "workbench.startupEditor": "none",
  "workbench.tree.enableStickyScroll": true,
  "workbench.tree.renderIndentGuides": "always",
  // == Other ==
  "files.associations": {
    "*.gen": "cpp",
    "*.inc": "cpp",
    "*.json": "jsonc"
  },
  "files.autoSaveWorkspaceFilesOnly": true,
  "security.workspace.trust.untrustedFiles": "open",
  "update.showReleaseNotes": false,
  // = AI =
  // == Chat ==
  "chat.agent.maxRequests": 50,
  "chat.tools.edits.autoApprove": {
    "": true
  },
  "chat.viewSessions.orientation": "stacked",
  // == Claude Code ==
  "claudeCode.preferredLocation": "sidebar",
  "claudeCode.useTerminal": true,
  // == GitHub Copilot ==
  "github.copilot.enable": {
    "*": true,
    "plaintext": true,
    "markdown": true,
    "scminput": false,
    "rust": true,
    "cpp": true
  },
  "github.copilot.nextEditSuggestions.enabled": true,
  "github.copilot.chat.commitMessageGeneration.instructions": [
    { "text": "Use conventional commit message format." }
  ],
  // = Languages =
  // == C/C++ ==
  "[c]": {
    "editor.defaultFormatter": "xaver.clang-format",
    "editor.indentSize": 2,
    "editor.tabSize": 2
  },
  "[cpp]": {
    "editor.defaultFormatter": "xaver.clang-format",
    "editor.indentSize": 2,
    "editor.tabSize": 2
  },
  "C_Cpp.clang_format_fallbackStyle": "LLVM",
  "C_Cpp.default.compilerPath": "/usr/bin/clang",
  "C_Cpp.default.cppStandard": "c++17",
  "C_Cpp.default.cStandard": "c17",
  "C_Cpp.default.intelliSenseMode": "macos-clang-arm64",
  "C_Cpp.formatting": "clangFormat",
  "C_Cpp.inlayHints.parameterNames.enabled": true,
  "C_Cpp.inlayHints.referenceOperator.enabled": true,
  // == CMake ==
  "cmake.configureOnEdit": false,
  "cmake.configureOnOpen": false,
  "cmake.ignoreCMakeListsMissing": true,
  "cmake.pinnedCommands": [
    "workbench.action.tasks.configureTaskRunner",
    "workbench.action.tasks.runTask"
  ],
  "cmake.showConfigureWithDebuggerNotification": false,
  // == Haskell ==
  "haskell.manageHLS": "GHCup",
  // == Json ==
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.suggest.insertMode": "replace",
    "editor.quickSuggestions": {
      "strings": true
    }
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "json.schemaDownload.trustedDomains": {
    "https://developer.microsoft.com/json-schemas/": true,
    "https://json-schema.org/": true,
    "https://json.schemastore.org/": true,
    "https://opencode.ai": true,
    "https://raw.githubusercontent.com/devcontainers/spec/": true,
    "https://raw.githubusercontent.com/microsoft/vscode/": true,
    "https://schemastore.azurewebsites.net/": true,
    "https://schemastore.org/": true,
    "https://www.schemastore.org/": true,
    "https://models.dev/": true
  },
  // == Log ==
  "[log]": {
    "editor.wordWrap": "on"
  },
  // == Makefile ==
  "makefile.configureOnOpen": false,
  // == Markdown ==
  "[markdown]": {
    "editor.defaultFormatter": "dprint.dprint",
  },
  // == Python ==
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.indentSize": 4,
    "editor.tabSize": 4
  },
  "python.defaultInterpreterPath": "/opt/homebrew/bin/python3.14",
  // == Rust ==
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer",
    "editor.indentSize": 4,
    "editor.rulers": [120],
    "editor.tabSize": 4
  },
  "rust-analyzer.check.command": "clippy",
  // == Web Development ==
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[typescript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  // = Extensions =
  "extensions.experimental.affinity": {
    "asvetliakov.vscode-neovim": 1
  },
  "extensions.ignoreRecommendations": true,
  // == Bookmarks ==
  "bookmarks.saveBookmarksInProject": true,
  // == Center Editor Window ==
  "center-editor-window.offset": 0,
  // == code tour ==
  "codetour.showMarkers": false,
  // == Color Highlight ==
  "color-highlight.languages": [
    "javascript",
    "typescript",
    "json",
    "html",
    "css",
    "jsx",
    "tsx"
  ],
  // == Git ==
  "git.enableSmartCommit": true,
  "git.openRepositoryInParentFolders": "never",
  // == GitLens ==
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4.1",
  "gitlens.rebaseEditor.openOnPausedRebase": false,
  // == Hex Editor ==
  "hexeditor.columnWidth": 16,
  "hexeditor.defaultEndianness": "little",
  "hexeditor.inspectorType": "aside",
  "hexeditor.showDecodedText": true,
  // == Indent Rainbow ==
  "indentRainbow.errorColor": "rgba(128,32,32,0.2)",
  // == lldb ==
  "lldb.suppressUpdateNotifications": true
  // = other settings =
}
