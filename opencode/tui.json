{
  "$schema": "https://opencode.ai/tui.json",
  "keybinds": {
    "input_backspace": "backspace,ctrl+h",
    "input_submit": "ctrl+return,super+return",
    "input_newline": "return,shift+return,ctrl+j",
    "history_previous": "up,ctrl+p",
    "history_next": "down,ctrl+n",
    "command_list": "none",
    "session_new": "<leader>n"
  }
}
